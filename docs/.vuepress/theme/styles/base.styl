.content-box{
    margin: 0 auto
    position relative
    width: 1024px
    height 100%
    display: flex
    justify-content: center
}
@media (max-width: $MQNarrow)
  .content-box{
    width: 100%
    height 100%
}
.catalog{
    display: none
    }

// wide mobile
@media (max-width: $MQMobile)
  .content-box{
    width: 100%
    height 100%
    display: block
}
.catalog{
    display: none
    }

// narrow mobile
@media (max-width: $MQMobileNarrow)
 .content-box{
    width: 100%
    height 100%
    display: block
}
.catalog{
    display: none
    }

// content
.content{
    // height 100%
    max-width 800px;
    padding:3em 1em;
    // overflow scroll
    box-sizing: border-box;
    overflow-x: hidden
    position relative !important
    }

// catalog
// .catalog-box {
//     min-width 200px
//     overflow hidden
//     position absolute
//     background: #ffffff
//     z-index: 9999
// }
.catalog {
position:fixed;
margin:auto;
top:10em;
transform: translateX(600px);
width:400px;
height:500px;
overflow-y auto
background: #ffffff
}
.level1 {
    font-weight bold 
    font-size 1.5em
}

.level2 {
    color #252525 
    font-weight bold 
    font-size 1em
}

.level3 {
    font-size 0.8em 
    padding-left 1em 
    line-height 2em
}
// layout 
.all-box{
    // height 100%;
    width: 100%;
    position relative
    }
    // 解决vue高度100%无效问题
html,body,#app{
 height: 100%;
}
