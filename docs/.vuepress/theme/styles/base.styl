// content
.content{
    max-width 750px;
    margin: 0 auto;
    padding: 0.5em;
    }
// catalog
.catalog {
    position fixed
    right:  0
    width 20em
}
.level1 {
    font-weight bold 
    font-size 1.5em
}

.level2 {
    color #252525 
    font-weight bold 
    font-size 1em
}

.level3 {
    font-size 0.8em 
    padding-left 1em 
    line-height 2em
}
// layout 
.big-box{
    height 100%;
    width: 100%;
    }
    // 解决vue高度100%无效问题
html,body,#app{
 height: 100%;
}